    "contentUrl": "https://nacho.cerberauth.com/logos/microsoft-entra-id.svg"
  },
  "website": "https://learn.microsoft.com/en-us/entra/external-id/",
  "license": "Proprietary",
  "nationality": "USA",
  "pricing": {
    "hasFreeTier": true,
    "freeTierLimit": "50,000 MAU/month",
    "pricingModel": "mau",
    "pricingUrl": "https://azure.microsoft.com/en-us/pricing/details/active-directory/external-identities/",
    "plans": [
