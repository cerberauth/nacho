{
  "$schema": "https://schemas.cerberauth.com/content/draft/2024-09/features.schema.json",
  "name": "FusionAuth",
  "abstract": "Self-hosted CIAM with a free Community edition supporting unlimited users. Enterprise-grade compliance certifications (SOC 2, HIPAA, PCI-DSS). Includes gaming platform SSO, extensive Lambda extensibility, and Connectors for custom database migration.",
  "identifier": "fusionauth",
  "icon": {
    "contentUrl": "https://nacho.cerberauth.com/logos/fusionauth.svg"
  },
  "website": "https://fusionauth.io",
  "github": "https://github.com/FusionAuth",
  "license": "Proprietary",
  "nationality": "USA",
  "pricing": {
    "hasFreeTier": true,
    "freeTierLimit": "Unlimited (Community edition, self-hosted)",
    "pricingModel": "mau",
    "pricingUrl": "https://fusionauth.io/pricing",
    "plans": [
      { "name": "Community", "price": "Free (self-hosted)" },
      { "name": "Starter", "price": "$0.00018/MAU" },
      { "name": "Essentials", "price": "$0.00090/MAU" },
      { "name": "Enterprise", "price": "Custom" }
    ]
  },
  "featureList": [
    {
      "identifier": "username_and_password_authentication",
      "status": "supported",
      "links": ["https://fusionauth.io/docs/lifecycle/authenticate-users/"]
    },
    {
      "identifier": "social_sign_in_authentication",
      "status": "supported",
      "description": "Includes gaming SSO: Epic, Nintendo, PlayStation, Steam, Xbox. 30+ built-in providers.",
      "links": ["https://fusionauth.io/docs/lifecycle/authenticate-users/identity-providers/"]
    },
    {
      "identifier": "passkey_authentication",
      "status": "supported",
      "links": ["https://fusionauth.io/docs/lifecycle/authenticate-users/passwordless/webauthn"]
    },
    {
      "identifier": "email_passwordless_authentication",
      "status": "supported",
      "links": ["https://fusionauth.io/docs/lifecycle/authenticate-users/passwordless/"]
    },
    {
      "identifier": "phone_passwordless_authentication",
