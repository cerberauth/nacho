    {
      "identifier": "bulk_user_import",
      "status": "supported",
      "links": ["https://fusionauth.io/docs/apis/users#import-users"]
    },
    {
      "identifier": "password_hash_import",
      "status": "supported",
      "description": "Import bcrypt, salted SHA, MD5, and other hash formats.",
