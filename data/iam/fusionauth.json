      "links": ["https://fusionauth.io/docs/lifecycle/authenticate-users/multi-factor-authentication"]
    },
    {
      "identifier": "push_notification_mfa",
      "status": "not_supported"
    },
    {
      "identifier": "adaptive_mfa",
      "status": "supported",
      "description": "Adaptive MFA via threat detection and step-up rules.",
      "links": ["https://fusionauth.io/docs/operate/secure-and-monitor/advanced-threat-detection"]
    },
    {
      "identifier": "cisco_duo_mfa",
      "status": "not_supported",
