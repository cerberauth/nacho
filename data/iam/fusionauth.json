    },
    {
      "identifier": "bulk_user_export",
      "status": "supported",
      "links": ["https://fusionauth.io/docs/apis/users#export-users"]
    },
    {
      "identifier": "bulk_user_update_delete",
      "status": "supported",
      "description": "Bulk delete via REST API endpoint DELETE /api/user/bulk. Update via individual User API.",
      "links": ["https://fusionauth.io/docs/apis/users"]
    },
    {
      "identifier": "upsert_on_import",
      "status": "not_supported",
      "description": "Import API is designed for initial data loading only. Duplicate detection via validateDbConstraints param returns 400/500; no upsert semantics.",
      "links": ["https://fusionauth.io/docs/apis/users#import-users"]
    },
    {
      "identifier": "legacy_username_import",
      "status": "supported",
      "description": "Usernames are stored and matched exactly as provided, including special characters and whitespace.",
      "links": ["https://fusionauth.io/docs/lifecycle/migrate-users/"]
    },
    {
      "identifier": "mfa_enrollment_import",
      "status": "supported",
      "description": "TOTP and SMS/email MFA enrollments can be imported via twoFactor fields in the import JSON or user update API.",
      "links": ["https://fusionauth.io/docs/apis/users#import-users"]
    },
    {
      "identifier": "inbound_scim_provisioning",
      "status": "supported",
      "description": "Inbound SCIM 2.0 provisioning.",
      "links": ["https://fusionauth.io/docs/lifecycle/provision-users/scim/"]
    },
    {
      "identifier": "outbound_scim_provisioning",
      "status": "not_supported",
      "description": "FusionAuth acts as a SCIM server (inbound) only, not a SCIM client. Webhooks can be used as an alternative for pushing changes.",
      "links": ["https://fusionauth.io/docs/lifecycle/migrate-users/scim/"]
    },
    {
      "identifier": "scim_groups",
      "status": "supported",
      "description": "SCIM group provisioning supported. Lambdas map incoming SCIM Group JSON to FusionAuth Group objects.",
      "links": ["https://fusionauth.io/docs/apis/scim/scim-group"]
    },
    {
      "identifier": "jit_provisioning",
      "status": "supported",
