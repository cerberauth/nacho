    },
    {
      "identifier": "fine_grained_authorization",
      "status": "partial",
      "description": "FusionAuth Entity System provides a relationship-based access control model. FusionAuth FGA by Permify (acquired 2025) adds full RBAC/ABAC/ReBAC.",
