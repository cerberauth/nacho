      "links": ["https://fusionauth.io/docs/lifecycle/manage-users/account-management/two-factor-email"]
    },
    {
      "identifier": "phone_code_mfa",
      "status": "supported",
      "description": "SMS-based MFA codes via configured Messenger. Available on paid plans only.",
      "links": ["https://fusionauth.io/docs/lifecycle/manage-users/account-management/two-factor-sms"]
