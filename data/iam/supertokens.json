    { "identifier": "per_org_branding", "status": "not_supported" },
    { "identifier": "per_org_mfa_policy", "status": "not_supported" },
    { "identifier": "inbound_scim_provisioning", "status": "not_supported" },
    { "identifier": "universal_login_customization", "status": "not_supported", "description": "Embedded-only architecture — no hosted login page" },
    { "identifier": "embedded_login", "status": "supported", "description": "Core differentiator — auth on your domain, no redirects" },
    { "identifier": "custom_domain", "status": "supported", "description": "Auth runs on your domain by default" },
    { "identifier": "white_label", "status": "supported" },
    { "identifier": "localization", "status": "partial" },
    { "identifier": "prebuilt_ui_components", "status": "supported", "description": "Pre-built React and React Native UI components" },
    { "identifier": "custom_database_connections", "status": "supported", "description": "PostgreSQL or MySQL" },
    { "identifier": "oidc_federation", "status": "supported", "description": "Available on Enterprise plan.", "links": ["https://supertokens.com/docs/additional-verification/sso/overview"] },
