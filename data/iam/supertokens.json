{
  "$schema": "https://schemas.cerberauth.com/content/draft/2024-09/features.schema.json",
  "name": "SuperTokens",
  "abstract": "Open-source embedded authentication with no redirects — auth runs on your domain. Recipe-based modular architecture, self-hostable on any infrastructure, with optional managed cloud.",
  "identifier": "supertokens",
  "icon": {
    "contentUrl": "https://nacho.cerberauth.com/logos/supertokens.svg"
  },
