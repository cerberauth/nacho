  "license": "Apache 2.0",
  "pricing": {
    "hasFreeTier": true,
    "freeTierLimit": "Unlimited (self-hosted)",
    "pricingModel": "mau",
    "pricingUrl": "https://supertokens.com/pricing",
    "plans": [
      { "name": "Self-hosted", "price": "Free" },
      { "name": "Managed Cloud", "price": "$0.02/MAU" },
      { "name": "Enterprise", "price": "Custom" }
    ]
  },
  "featureList": [
    { "identifier": "username_and_password_authentication", "status": "supported" },
    { "identifier": "social_sign_in_authentication", "status": "supported", "description": "Google, GitHub, Facebook, Apple plus custom OIDC/OAuth providers" },
    { "identifier": "magic_link_authentication", "status": "supported" },
    { "identifier": "phone_passwordless_authentication", "status": "supported" },
