    { "identifier": "email_code_mfa", "status": "partial", "description": "Available as MFA add-on" },
    { "identifier": "push_notification_mfa", "status": "not_supported" },
    { "identifier": "adaptive_mfa", "status": "not_supported" },
    { "identifier": "saml2_protocol", "status": "supported" },
    { "identifier": "oidc_protocol", "status": "supported" },
    { "identifier": "machine_to_machine", "status": "supported", "description": "Available on Enterprise plan" },
    { "identifier": "user_search", "status": "supported" },
    { "identifier": "bulk_user_import", "status": "supported" },
    { "identifier": "user_metadata", "status": "supported" },
    { "identifier": "progressive_profiling", "status": "not_supported" },
