{
  "$schema": "https://schemas.cerberauth.com/content/draft/2024-09/features.schema.json",
  "name": "Supabase Auth",
  "abstract": "Open-source Postgres-native authentication with RLS-based authorization. 50K MAU free tier, self-hostable, bundled with a full backend platform including database, storage, and edge functions.",
  "identifier": "supabase-auth",
  "icon": {
    "contentUrl": "https://nacho.cerberauth.com/logos/supabase-auth.svg"
  },
  "website": "https://supabase.com/docs/guides/auth",
  "license": "Apache 2.0",
  "pricing": {
    "hasFreeTier": true,
    "freeTierLimit": "50,000 MAU",
    "pricingModel": "mau",
    "pricingUrl": "https://supabase.com/pricing",
    "plans": [
      { "name": "Free", "price": "Free (50K MAU)" },
      { "name": "Pro", "price": "$25/month" },
      { "name": "Team", "price": "$599/month" },
      { "name": "Enterprise", "price": "Custom" }
    ]
  },
  "featureList": [
    { "identifier": "username_and_password_authentication", "status": "supported" },
    { "identifier": "social_sign_in_authentication", "status": "supported", "description": "20+ OAuth providers" },
    { "identifier": "magic_link_authentication", "status": "supported" },
    { "identifier": "phone_passwordless_authentication", "status": "supported" },
    { "identifier": "email_passwordless_authentication", "status": "supported" },
    { "identifier": "passkey_authentication", "status": "not_supported" },
    { "identifier": "anonymous_authentication", "status": "supported" },
    { "identifier": "totp_mfa", "status": "supported" },
    { "identifier": "phone_code_mfa", "status": "supported", "description": "Phone MFA as paid factor on Pro+" },
    { "identifier": "email_code_mfa", "status": "not_supported" },
    { "identifier": "push_notification_mfa", "status": "not_supported" },
    { "identifier": "adaptive_mfa", "status": "not_supported" },
    { "identifier": "saml2_protocol", "status": "supported", "description": "Available on Pro+ at $0.015/SAML SSO MAU" },
    { "identifier": "oidc_protocol", "status": "supported" },
    { "identifier": "machine_to_machine", "status": "supported", "description": "OAuth 2.1 server for M2M and MCP auth" },
    { "identifier": "user_search", "status": "supported" },
    { "identifier": "bulk_user_import", "status": "supported" },
    { "identifier": "user_metadata", "status": "supported" },
    { "identifier": "progressive_profiling", "status": "not_supported" },
    { "identifier": "account_linking", "status": "supported" },
    { "identifier": "rbac", "status": "partial", "description": "Via Row Level Security + custom claims; no built-in RBAC UI" },
    { "identifier": "abac", "status": "supported", "description": "Row Level Security policies provide attribute-based control" },
    { "identifier": "fine_grained_authorization", "status": "partial", "description": "RLS provides row-level granularity but no ReBAC graph model" },
    { "identifier": "api_authorization", "status": "supported" },
    { "identifier": "brute_force_protection", "status": "supported" },
    { "identifier": "breached_password_detection", "status": "not_supported" },
    { "identifier": "bot_detection", "status": "not_supported" },
    { "identifier": "suspicious_ip_throttling", "status": "not_supported" },
    { "identifier": "device_fingerprinting", "status": "not_supported" },
    { "identifier": "organizations_multitenancy", "status": "not_supported", "description": "Must be built manually via RLS and custom tables" },
    { "identifier": "per_org_branding", "status": "not_supported" },
    { "identifier": "per_org_mfa_policy", "status": "not_supported" },
    { "identifier": "inbound_scim_provisioning", "status": "not_supported" },
    { "identifier": "universal_login_customization", "status": "supported" },
    { "identifier": "embedded_login", "status": "supported" },
    { "identifier": "custom_domain", "status": "supported", "description": "Available on Pro+" },
    { "identifier": "white_label", "status": "supported" },
    { "identifier": "localization", "status": "partial" },
    { "identifier": "prebuilt_ui_components", "status": "supported", "description": "supabase-js SDK plus community UI kits" },
    { "identifier": "custom_database_connections", "status": "supported", "description": "Postgres is the database — fully accessible" },
    { "identifier": "oidc_federation", "status": "not_supported" },
    { "identifier": "saml_federation", "status": "supported", "description": "SAML 2.0 SSO per organization available on Pro+.", "links": ["https://supabase.com/docs/guides/auth/sso/auth-sso-saml"] },
    { "identifier": "active_directory_ldap", "status": "not_supported" },
    { "identifier": "native_webhooks", "status": "supported", "description": "Database webhooks and Edge Functions" },
    { "identifier": "actions_extensibility", "status": "supported", "description": "Edge Functions and database triggers" },
    { "identifier": "terraform_provider", "status": "supported" },
    { "identifier": "lazy_migration", "status": "partial" },
    { "identifier": "password_hash_import", "status": "partial" },
    { "identifier": "login_analytics", "status": "partial" },
    { "identifier": "audit_log_retention", "status": "partial", "description": "Via Postgres logs" },
    { "identifier": "audit_log_streaming", "status": "partial", "description": "Log drains available on Pro+" },
    { "identifier": "consent_management", "status": "not_supported" },
    { "identifier": "region_deployment", "status": "supported", "description": "12+ AWS regions available on Pro+.", "values": ["US", "EU", "AP", "CA", "SA"] },
    { "identifier": "private_cloud_deployment", "status": "supported", "description": "Supabase Cloud runs on AWS; self-hosted deployable on any cloud.", "values": ["AWS", "Azure", "GCP"] },
    { "identifier": "nocode_flow_builder", "status": "not_supported" },
    { "identifier": "identity_proofing", "status": "not_supported" },
    { "identifier": "decentralized_identity", "status": "not_supported" },
    { "identifier": "billing_integration", "status": "not_supported" },
    { "identifier": "agentic_identity", "status": "partial", "description": "OAuth 2.1 server supports MCP auth flows" }
  ]
}
