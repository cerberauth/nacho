{
  "$schema": "https://schemas.cerberauth.com/content/draft/2024-09/features.schema.json",
  "name": "Amazon Cognito",
  "abstract": "AWS-native CIAM with three feature tiers (Lite/Essentials/Plus). Offers the lowest per-MAU cost at scale and deep AWS ecosystem integration via Lambda triggers.",
  "identifier": "aws-cognito",
  "icon": {
    "contentUrl": "https://nacho.cerberauth.com/logos/aws-cognito.svg"
  },
  "website": "https://aws.amazon.com/cognito/",
  "license": "Proprietary",
  "pricing": {
    "hasFreeTier": true,
    "freeTierLimit": "50,000 MAU/month",
    "pricingModel": "mau",
    "pricingUrl": "https://aws.amazon.com/cognito/pricing/",
    "plans": [
      { "name": "Free", "price": "Free (50K MAU)" },
      { "name": "Lite", "price": "$0.0055/MAU" },
      { "name": "Essentials", "price": "$0.015/MAU" },
      { "name": "Plus", "price": "$0.023/MAU" }
    ]
  },
  "featureList": [
    {
      "identifier": "username_and_password_authentication",
      "status": "supported",
      "links": ["https://docs.aws.amazon.com/cognito/latest/developerguide/user-pool-settings-attributes.html"]
    },
    {
      "identifier": "social_sign_in_authentication",
      "status": "supported",
      "description": "Google, Facebook, Apple, Amazon, custom OIDC/SAML providers.",
      "links": ["https://docs.aws.amazon.com/cognito/latest/developerguide/cognito-user-pools-social-idp.html"]
    },
    {
      "identifier": "passkey_authentication",
      "status": "supported",
      "description": "Available on Essentials and Plus tiers.",
      "links": ["https://docs.aws.amazon.com/cognito/latest/developerguide/user-pools-passkeys.html"]
    },
    {
      "identifier": "email_passwordless_authentication",
