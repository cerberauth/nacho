    },
    {
      "identifier": "email_templates",
      "status": "supported",
      "description": "Customize email templates in the Firebase Console.",
      "links": ["https://firebase.google.com/docs/auth/web/manage-users"]
    },
    {
      "identifier": "custom_oidc_claims",
      "status": "supported",
      "description": "Custom claims added via Admin SDK. Limited to 1000 bytes total.",
      "links": ["https://firebase.google.com/docs/auth/admin/custom-claims"]
    },
    {
      "identifier": "nocode_flow_builder",
      "status": "not_supported"
    },
    {
      "identifier": "identity_proofing",
      "status": "not_supported"
    },
    {
      "identifier": "decentralized_identity",
      "status": "not_supported"
    },
    {
      "identifier": "billing_integration",
