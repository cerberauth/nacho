      "links": ["https://firebase.google.com/docs/auth"]
    },
    {
      "identifier": "management_api",
      "status": "supported",
      "description": "Firebase Admin SDK and REST API for user management.",
      "links": ["https://firebase.google.com/docs/auth/admin/manage-users"]
    },
    {
      "identifier": "authentication_api_rate_limits",
      "status": "unknown"
    },
    {
      "identifier": "actions_extensibility",
      "status": "supported",
      "description": "Blocking functions (beforeCreate, beforeSignIn) for custom auth logic. Cloud Functions for post-event hooks.",
      "links": ["https://firebase.google.com/docs/auth/admin/blocking-functions"]
    },
    {
      "identifier": "typescript_in_actions",
      "status": "supported",
      "description": "Cloud Functions for Firebase supports TypeScript."
    },
    {
      "identifier": "custom_domain",
      "status": "supported",
      "description": "Custom domain via Firebase Hosting.",
      "links": ["https://firebase.google.com/docs/hosting/custom-domain"]
    },
    {
      "identifier": "deploy_cli",
      "status": "supported",
      "description": "Firebase CLI for deploying auth rules and functions.",
      "links": ["https://firebase.google.com/docs/cli"]
    },
    {
      "identifier": "terraform_provider",
      "status": "partial",
      "description": "Google Cloud Terraform provider covers some Firebase Identity Platform resources.",
      "links": ["https://registry.terraform.io/providers/hashicorp/google/latest/docs"]
    },
    {
      "identifier": "custom_database_connections",
      "status": "not_supported",
      "description": "Firebase Auth uses its own user store. Custom database connections not supported."
    },
    {
      "identifier": "native_webhooks",
      "status": "supported",
      "description": "Blocking functions and Cloud Functions Firestore triggers act as event hooks.",
      "links": ["https://firebase.google.com/docs/auth/admin/blocking-functions"]
    },
    {
      "identifier": "universal_login_customization",
      "status": "supported",
      "description": "FirebaseUI is fully customizable with custom styles and strings.",
      "links": ["https://firebase.google.com/docs/auth/web/firebaseui"]
    },
    {
      "identifier": "custom_email_provider",
      "status": "not_supported",
