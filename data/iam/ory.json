{
  "$schema": "https://schemas.cerberauth.com/content/draft/2024-09/features.schema.json",
  "name": "Ory",
  "abstract": "Open-source (Apache 2.0) microservice-based IAM/CIAM platform. Modular architecture: Ory Kratos (identity), Ory Hydra (OAuth2/OIDC, OpenID Certified), Ory Keto (Zanzibar-based FGA permissions), Ory Oathkeeper (Zero Trust proxy). Unique aDAU pricing model.",
  "identifier": "ory",
  "icon": {
    "contentUrl": "https://nacho.cerberauth.com/logos/ory.svg"
  },
  "website": "https://www.ory.com",
  "github": "https://github.com/ory",
  "license": "Apache 2.0",
  "pricing": {
    "hasFreeTier": true,
    "freeTierLimit": "Unlimited (self-hosted) / 1,000 aDAU (Ory Network)",
    "pricingModel": "mau",
    "pricingUrl": "https://www.ory.com/pricing",
    "plans": [
      {
        "name": "Open Source",
        "price": "Free (self-hosted)"
      },
      {
        "name": "Developer",
        "price": "Free (1K aDAU)"
      },
      {
        "name": "Growth",
        "price": "$29/month"
      },
      {
        "name": "Scale",
        "price": "Custom"
      }
    ]
  },
