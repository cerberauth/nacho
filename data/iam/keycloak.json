{
  "$schema": "https://schemas.cerberauth.com/content/draft/2024-09/features.schema.json",
  "name": "Keycloak",
  "abstract": "Open-source (Apache 2.0) IAM/CIAM by Red Hat. Zero licensing cost with unlimited users. Most feature-rich open-source option with full SPI extensibility. Requires self-hosting and DevOps expertise.",
  "identifier": "keycloak",
  "icon": {
    "contentUrl": "https://nacho.cerberauth.com/logos/keycloak.svg"
  },
  "website": "https://www.keycloak.org",
  "github": "https://github.com/keycloak/keycloak",
  "license": "Apache 2.0",
  "pricing": {
    "hasFreeTier": true,
    "freeTierLimit": "Unlimited (self-hosted, open source)",
    "pricingModel": "open-source",
    "pricingUrl": "https://www.keycloak.org",
    "plans": [
      { "name": "Open Source", "price": "Free (self-hosted)" },
      { "name": "Red Hat SSO", "price": "Commercial support available" }
    ]
  },
  "featureList": [
    {
      "identifier": "username_and_password_authentication",
      "status": "supported",
      "links": ["https://www.keycloak.org/docs/latest/server_admin/index.html#_user-credentials"]
    },
    {
      "identifier": "social_sign_in_authentication",
      "status": "supported",
      "description": "12+ built-in providers plus any custom OIDC or SAML identity provider.",
      "links": ["https://www.keycloak.org/docs/latest/server_admin/index.html#social-identity-providers"]
    },
    {
      "identifier": "passkey_authentication",
      "status": "supported",
      "description": "WebAuthn passwordless and two-factor authentication.",
      "links": ["https://www.keycloak.org/docs/latest/server_admin/index.html#webauthn"]
    },
    {
      "identifier": "email_passwordless_authentication",
      "status": "supported",
      "description": "Email OTP for passwordless authentication.",
      "links": ["https://www.keycloak.org/docs/latest/server_admin/index.html#one-time-passwords"]
    },
    {
      "identifier": "phone_passwordless_authentication",
      "status": "partial",
      "description": "Phone OTP via custom SPI extension or third-party provider. No built-in SMS gateway."
    },
    {
      "identifier": "magic_link_authentication",
      "status": "partial",
      "description": "Magic link via custom authenticator SPI. Not available out-of-the-box."
    },
    {
      "identifier": "anonymous_authentication",
      "status": "not_supported"
    },
    {
      "identifier": "totp_mfa",
      "status": "supported",
      "links": ["https://www.keycloak.org/docs/latest/server_admin/index.html#time-based-one-time-password"]
    },
    {
      "identifier": "hotp_mfa",
      "status": "supported",
      "description": "HOTP (counter-based OTP) supported alongside TOTP.",
      "links": ["https://www.keycloak.org/docs/latest/server_admin/index.html#one-time-passwords"]
    },
    {
      "identifier": "u2f_mfa",
      "status": "supported",
      "description": "WebAuthn security keys for U2F-style authentication.",
      "links": ["https://www.keycloak.org/docs/latest/server_admin/index.html#webauthn"]
    },
    {
      "identifier": "webauthn_mfa",
      "status": "supported",
      "links": ["https://www.keycloak.org/docs/latest/server_admin/index.html#webauthn"]
    },
    {
      "identifier": "email_code_mfa",
      "status": "supported",
      "links": ["https://www.keycloak.org/docs/latest/server_admin/index.html#one-time-passwords"]
    },
    {
      "identifier": "phone_code_mfa",
      "status": "partial",
      "description": "SMS OTP via SPI extension. No built-in SMS provider."
    },
    {
      "identifier": "recovery_code_mfa",
      "status": "supported",
      "description": "Recovery Codes are a built-in required action since Keycloak 22+. Single-use backup codes generated at MFA enrollment.",
      "links": ["https://www.keycloak.org/docs/latest/server_admin/index.html#recovery-codes"]
    },
    {
      "identifier": "push_notification_mfa",
      "status": "not_supported"
    },
    {
      "identifier": "adaptive_mfa",
      "status": "not_supported",
      "description": "No built-in adaptive/risk-based MFA. Can be implemented via custom SPI."
    },
    {
      "identifier": "cisco_duo_mfa",
      "status": "partial",
      "description": "Cisco Duo integration available via community extension."
    },
    {
      "identifier": "step_up_authentication",
      "status": "supported",
      "links": ["https://www.keycloak.org/docs/latest/server_admin/index.html#step-up-mechanism"]
    },
    {
      "identifier": "oidc_protocol",
      "status": "supported",
      "links": ["https://www.keycloak.org/docs/latest/server_admin/index.html#oidc-clients"]
    },
    {
      "identifier": "saml2_protocol",
      "status": "supported",
      "links": ["https://www.keycloak.org/docs/latest/server_admin/index.html#saml-clients"]
    },
    {
      "identifier": "ws_federation_protocol",
      "status": "not_supported"
    },
    {
      "identifier": "machine_to_machine",
      "status": "supported",
      "description": "OAuth 2.0 client credentials grant natively supported.",
      "links": ["https://www.keycloak.org/docs/latest/server_admin/index.html#_client-credentials"]
    },
    {
      "identifier": "oidc_federation",
      "status": "supported",
      "links": ["https://www.keycloak.org/docs/latest/server_admin/index.html#_identity_broker"]
    },
    {
      "identifier": "saml_federation",
      "status": "supported",
      "links": ["https://www.keycloak.org/docs/latest/server_admin/index.html#_identity_broker"]
    },
    {
      "identifier": "active_directory_ldap",
      "status": "supported",
      "description": "Full LDAP and Active Directory federation with read/write sync.",
      "links": ["https://www.keycloak.org/docs/latest/server_admin/index.html#_ldap"]
    },
    {
      "identifier": "azure_ad_integration",
      "status": "supported",
      "description": "Azure AD/Entra ID federation via OIDC or SAML identity brokering."
    },
    {
      "identifier": "bulk_user_import",
      "status": "supported",
      "description": "Import users via Admin REST API or LDAP sync.",
      "links": ["https://www.keycloak.org/docs/latest/server_admin/index.html#admin-cli"]
    },
    {
      "identifier": "password_hash_import",
      "status": "supported",
      "description": "Import password hashes via Admin API with custom hashing algorithm support.",
      "links": ["https://www.keycloak.org/docs/latest/server_admin/index.html#_import-export"]
    },
    {
      "identifier": "bulk_user_export",
      "status": "supported",
      "description": "Export users via Admin REST API or realm export.",
      "links": ["https://www.keycloak.org/docs/latest/server_admin/index.html#_import-export"]
    },
    {
      "identifier": "bulk_user_update_delete",
      "status": "supported",
      "description": "Bulk operations via Admin REST API."
    },
    {
      "identifier": "upsert_on_import",
      "status": "supported",
      "description": "Partial Import API supports OVERWRITE, SKIP, and FAIL conflict strategies, enabling upsert behavior.",
      "links": ["https://www.keycloak.org/docs/latest/server_admin/index.html#importing-and-exporting-realms"]
    },
    {
      "identifier": "legacy_username_import",
      "status": "partial",
      "description": "Keycloak accepts a broad Unicode range via regex but username character handling is version-dependent. Spaces, CJK characters, and special symbols have caused regressions between versions (e.g., v23→v24). Import success depends on Keycloak version and specific characters involved."
    },
    {
      "identifier": "mfa_enrollment_import",
      "status": "supported",
      "description": "TOTP secrets can be imported via the JSON realm import format or the admin REST API using the credentials array with fields: secret (BASE32), digits, period, and algorithm.",
      "links": ["https://www.keycloak.org/docs/latest/server_admin/index.html#_import-export"]
    },
    {
      "identifier": "inbound_scim_provisioning",
      "status": "not_supported",
      "description": "No built-in SCIM support. Community extensions are available.",
      "links": ["https://github.com/Captain-P-Goldfish/scim-for-keycloak"]
    },
    {
      "identifier": "outbound_scim_provisioning",
      "status": "not_supported"
    },
    {
      "identifier": "scim_groups",
      "status": "not_supported"
    },
    {
      "identifier": "jit_provisioning",
      "status": "supported",
      "description": "JIT user provisioning during first federation login.",
      "links": ["https://www.keycloak.org/docs/latest/server_admin/index.html#_identity_broker_first_login"]
    },
    {
      "identifier": "lazy_migration",
      "status": "supported",
      "description": "Lazy migration via User Storage SPI for gradual migration from existing user stores.",
      "links": ["https://www.keycloak.org/docs/latest/server_development/index.html#_user-storage-spi"]
    },
    {
      "identifier": "self_service_profile_management",
      "status": "supported",
      "description": "Keycloak Account Console for self-service profile, MFA, and session management.",
      "links": ["https://www.keycloak.org/docs/latest/server_admin/index.html#using-the-account-console"]
    },
    {
      "identifier": "account_linking",
      "status": "supported",
      "description": "Link multiple identity providers to a single Keycloak account.",
      "links": ["https://www.keycloak.org/docs/latest/server_admin/index.html#_account-linking"]
    },
    {
      "identifier": "user_blocking",
      "status": "supported",
      "description": "Disable user accounts to prevent authentication."
    },
    {
      "identifier": "user_metadata",
      "status": "supported",
      "description": "Custom user attributes stored as user attributes in Keycloak.",
      "links": ["https://www.keycloak.org/docs/latest/server_admin/index.html#user-profile"]
    },
    {
      "identifier": "app_metadata",
      "status": "supported"
    },
    {
      "identifier": "metadata_size_limits",
      "status": "partial",
      "description": "Attribute value limits are database-level constraints, not formally documented in official docs. Unmanaged attributes support up to ~2048 characters in recent versions (extended from the historical 255-char limit). Limits are deployment-dependent."
    },
    {
      "identifier": "user_search",
      "status": "supported",
      "links": ["https://www.keycloak.org/docs/latest/server_admin/index.html#searching-for-users"]
    },
    {
      "identifier": "rbac",
      "status": "supported",
      "description": "Realm roles and client roles with composite roles support.",
      "links": ["https://www.keycloak.org/docs/latest/server_admin/index.html#assigning-permissions-and-roles-to-users"]
    },
    {
      "identifier": "organizations_multitenancy",
      "status": "supported",
      "description": "Organizations feature (since v26.0) and Realms for full tenant isolation.",
