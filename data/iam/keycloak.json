    },
    {
      "identifier": "fine_grained_authorization",
      "status": "supported",
      "description": "Resource, scope, and policy-based authorization via Keycloak Authorization Services.",
      "links": ["https://www.keycloak.org/docs/latest/authorization_services/index.html"]
    },
    {
      "identifier": "api_authorization",
      "status": "supported",
      "links": ["https://www.keycloak.org/docs/latest/authorization_services/index.html"]
    },
    {
      "identifier": "soc2_type2",
      "status": "unknown",
