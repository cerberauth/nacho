{
  "$schema": "https://schemas.cerberauth.com/content/draft/2024-09/features.schema.json",
  "name": "Clerk",
  "abstract": "Developer-first CIAM with best-in-class prebuilt React and Next.js components. Features a generous 50K MRU free tier, built-in Stripe billing integration, and an organization-first B2B data model.",
  "identifier": "clerk",
  "icon": {
    "contentUrl": "https://nacho.cerberauth.com/logos/clerk.svg"
  },
  "website": "https://clerk.com",
  "github": "https://github.com/clerkinc",
  "license": "Proprietary",
  "pricing": {
    "hasFreeTier": true,
    "freeTierLimit": "50,000 MRU",
    "pricingModel": "mau",
    "pricingUrl": "https://clerk.com/pricing",
    "plans": [
      { "name": "Free", "price": "Free" },
      { "name": "Pro", "price": "$20/month (annual) / $25/month" },
      { "name": "Business", "price": "$250/month (annual) / $300/month" },
      { "name": "Enterprise", "price": "Custom" }
    ]
  },
  "featureList": [
    {
      "identifier": "username_and_password_authentication",
      "status": "supported",
      "links": ["https://clerk.com/docs/authentication/configuration/sign-up-sign-in-options"]
    },
    {
      "identifier": "social_sign_in_authentication",
      "status": "supported",
      "description": "20+ OAuth providers. Free plan limited to 3 social connections; Pro and above allow unlimited connections.",
      "links": ["https://clerk.com/docs/authentication/social-connections/overview"]
    },
    {
      "identifier": "passkey_authentication",
      "status": "supported",
      "description": "Available on Pro plan and above.",
